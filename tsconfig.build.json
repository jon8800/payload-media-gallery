{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "incremental": false,
    "composite": false
  },
  "include": ["./src/**/*.ts", "./src/**/*.tsx"],
  "exclude": ["dev", ".next", "dist", "node_modules"]
}
